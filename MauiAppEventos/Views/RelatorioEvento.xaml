<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppEventos.Views.RelatorioEvento"
             Title="Resumo do Evento"
             BackgroundColor="#F5F6FA"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="📅 Resumo do Evento" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#2F3640"
                   HorizontalOptions="Center" 
                   Margin="0,10,0,10" />

            <Frame BackgroundColor="White" 
                   BorderColor="Transparent" 
                   CornerRadius="12" 
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="INFORMAÇÕES GERAIS" 
                           FontSize="13" 
                           FontAttributes="Bold" 
                           TextColor="#718093" 
                           CharacterSpacing="1" />

                    <BoxView HeightRequest="1" BackgroundColor="#DCDDE1" Margin="0,0,0,5" />

                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *" RowSpacing="8" ColumnSpacing="10">
                        <Label Text="Nome:" FontAttributes="Bold" TextColor="#353B48" Grid.Row="0" Grid.Column="0" />
                        <Label Text="{Binding NomeDoEvento}" TextColor="#2F3640" Grid.Row="0" Grid.Column="1" />

                        <Label Text="Local:" FontAttributes="Bold" TextColor="#353B48" Grid.Row="1" Grid.Column="0" />
                        <Label Text="{Binding LocalDoEvento}" TextColor="#2F3640" Grid.Row="1" Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" 
                   BorderColor="Transparent" 
                   CornerRadius="12" 
                   HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="PERÍODO DO EVENTO" 
                           FontSize="13" 
                           FontAttributes="Bold" 
                           TextColor="#718093" 
                           CharacterSpacing="1" 
                           HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" BackgroundColor="#DCDDE1" />

                    <Grid ColumnDefinitions="*, *" BackgroundColor="Transparent">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                            <Label Text="🛫 INÍCIO" FontSize="11" TextColor="#718093" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="{Binding DataInicio, StringFormat='{0:dd/MM/yyyy}'}" FontSize="15" FontAttributes="Bold" TextColor="#2F3640" HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                            <Label Text="🛬 ENCERRAMENTO" FontSize="11" TextColor="#718093" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="{Binding DataFim, StringFormat='{0:dd/MM/yyyy}'}" FontSize="15" FontAttributes="Bold" TextColor="#2F3640" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" 
                   BorderColor="Transparent" 
                   CornerRadius="12" 
                   HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="FINANCEIRO E PARTICIPAÇÃO" 
                           FontSize="13" 
                           FontAttributes="Bold" 
                           TextColor="#718093" 
                           CharacterSpacing="1" />

                    <BoxView HeightRequest="1" BackgroundColor="#DCDDE1" Margin="0,0,0,5" />

                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="10">
                        <Label Text="👥 Público Estimado:" TextColor="#353B48" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                        <Label Text="{Binding NroParticipantes}" FontAttributes="Bold" TextColor="#2F3640" Grid.Row="0" Grid.Column="1" />

                        <Label Text="🎟️ Valor do Convite:" TextColor="#353B48" VerticalOptions="Center" Grid.Row="1" Grid.Column="0" />
                        <Label Text="{Binding CustoPorParticipante, StringFormat='R$ {0:F2}'}" TextColor="#2F3640" Grid.Row="1" Grid.Column="1" />

                        <Label Text="💰 Total Arrecadado:" FontAttributes="Bold" FontSize="16" TextColor="#2F3640" VerticalOptions="Center" Grid.Row="2" Grid.Column="0" />
                        <Label Text="{Binding VlrTotal, StringFormat='R$ {0:F2}'}" FontAttributes="Bold" FontSize="18" TextColor="#4CD137" Grid.Row="2" Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Voltar para o Cadastro"
                    BackgroundColor="#353B48"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="0,15,0,0"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=Navigation.PopAsync}"
                    Clicked="Button_Clicked_Voltar_Fake" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>